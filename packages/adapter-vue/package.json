{
  "name": "horizon-mfe/vue",
  "version": "0.1.0",
  "description": "Horizon adapter for Vue 3 — mount any Vue component as a micro-frontend",
  "main": "dist/adapter-vue.umd.js",
  "module": "dist/adapter-vue.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/adapter-vue.js",
      "require": "./dist/adapter-vue.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "vite build --watch --minify false",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "horizon-mfe": "*",
    "vue": ">=3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "horizon-mfe": "workspace:*",
    "typescript": "^5.4.2",
    "vite": "^5.1.0",
    "vue": "^3.4.21"
  }
}
