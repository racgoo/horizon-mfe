{
  "name": "horizon-mfe/svelte",
  "version": "0.1.0",
  "description": "Horizon adapter for Svelte — mount any Svelte component as a micro-frontend",
  "main": "dist/adapter-svelte.umd.js",
  "module": "dist/adapter-svelte.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/adapter-svelte.js",
      "require": "./dist/adapter-svelte.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "vite build --watch --minify false",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "horizon-mfe": "*",
    "svelte": ">=4"
  },
  "devDependencies": {
    "horizon-mfe": "workspace:*",
    "svelte": "^4.2.0",
    "typescript": "^5.4.2",
    "vite": "^5.1.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0"
  }
}
